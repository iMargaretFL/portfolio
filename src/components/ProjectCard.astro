---
const { title, description, tags = [] } = Astro.props;
---

<article class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 transition hover:border-white/25 hover:bg-white/[0.06]">
  <div class="mb-6 aspect-video rounded-2xl bg-neutral-800"></div>

  <h3 class="text-xl font-semibold text-white">{title}</h3>

  <p class="mt-3 text-sm leading-6 text-neutral-400">{description}</p>

  <div class="mt-5 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-neutral-400">
        {tag}
      </span>
    ))}
  </div>
</article>
