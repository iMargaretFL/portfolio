---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Ad Graphics',
    description: 'Scroll-stopping creative for social media, paid ads, campaigns, and product promotions.',
    tags: ['Social Ads', 'Campaigns', 'Digital'],
  },
  {
    title: 'Landing Pages',
    description: 'Clean, conversion-focused landing page designs for products, services, and campaigns.',
    tags: ['Web Design', 'UX', 'Marketing'],
  },
  {
    title: 'Branding',
    description: 'Visual identity systems including logos, colors, typography, brand direction, and creative assets.',
    tags: ['Logo Design', 'Identity', 'Brand Systems'],
  },
  {
    title: 'Presentations',
    description: 'Professional pitch decks, business presentations, and branded slides that feel polished and clear.',
    tags: ['Pitch Decks', 'Slides', 'Business'],
  },
  {
    title: 'Packaging',
    description: 'Product packaging concepts and layouts designed to look attractive, clear, and market-ready.',
    tags: ['Product Design', 'Print', 'Packaging'],
  },
  {
    title: 'Photography',
    description: 'Clean product, lifestyle, and brand photography for marketing, websites, and social content.',
    tags: ['Product', 'Lifestyle', 'Content'],
  },
];
---

<Layout>
  <main class="min-h-screen bg-[#f7f5ef] text-[#1f2933]">
    <header class="sticky top-0 z-50 border-b border-black/5 bg-[#f7f5ef]/80 backdrop-blur-xl">
      <div class="mx-auto grid max-w-6xl grid-cols-3 items-center px-6 py-5">
        <a href="/" class="text-lg font-semibold tracking-tight">
          Margaret Bus
        </a>

        <nav class="hidden items-center justify-center gap-8 text-sm font-medium text-[#6b7280] md:flex">
          <a href="#projects" class="transition hover:text-[#1f2933]">Projects</a>
          <a href="#about" class="transition hover:text-[#1f2933]">About</a>
          <a href="#contact" class="transition hover:text-[#1f2933]">Contact</a>
        </nav>

        <div class="flex justify-end">
          <a
            href="#contact"
            class="rounded-full bg-[#1f2933] px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-[#111827]"
          >
            Work with me
          </a>
        </div>
      </div>
    </header>

    <section class="relative overflow-hidden px-6 py-24 md:py-32">
      <div class="absolute left-1/2 top-0 z-0 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-[#f0d7b8] opacity-60 blur-3xl"></div>

      <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-16 md:grid-cols-[1.1fr_0.9fr]">
        <div>
          <p class="mb-5 text-sm font-semibold uppercase tracking-[0.3em] text-[#9a6a3a]">
            Senior Graphic Designer
          </p>

          <h1 class="font-display max-w-4xl text-5xl font-semibold tracking-tight text-[#151922] md:text-7xl">
		    Design that moves the metric, <em class="italic text-[#9a6a3a]">not just the eye.</em>
		 </h1>

          <p class="mt-7 max-w-2xl text-lg leading-8 text-[#5f6875]">
            I create ad graphics, landing pages, branding, presentations, packaging, and photography for brands that need polished, effective visual communication.
          </p>

          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href="#projects"
              class="rounded-full bg-[#9a6a3a] px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-[#9a6a3a]/20 transition hover:bg-[#7b512a]"
            >
              View Projects
            </a>

            <a
              href="#contact"
              class="rounded-full border border-[#d8c8b6] bg-white/70 px-6 py-3 text-sm font-semibold text-[#1f2933] transition hover:bg-white"
            >
              Contact Me
            </a>
          </div>
        </div>

        <div class="rounded-[2rem] border border-black/5 bg-white p-4 shadow-2xl shadow-black/10">
          <div class="rounded-[1.5rem] bg-[#faf8f3] p-6">
            <div class="mb-8 flex items-center gap-2">
              <span class="h-3 w-3 rounded-full bg-[#f87171]"></span>
              <span class="h-3 w-3 rounded-full bg-[#fbbf24]"></span>
              <span class="h-3 w-3 rounded-full bg-[#34d399]"></span>
            </div>

            <div class="space-y-4">
              <div class="rounded-2xl bg-white p-5 shadow-sm">
                <p class="text-sm font-semibold text-[#9a6a3a]">Performance</p>
                <p class="mt-2 text-3xl font-semibold">95+</p>
                <p class="mt-1 text-sm text-[#6b7280]">Lighthouse-focused builds</p>
              </div>

              <div class="rounded-2xl bg-white p-5 shadow-sm">
                <p class="text-sm font-semibold text-[#9a6a3a]">Stack</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <span class="rounded-full bg-[#f1eadf] px-3 py-1 text-xs font-medium">Astro</span>
                  <span class="rounded-full bg-[#f1eadf] px-3 py-1 text-xs font-medium">Tailwind</span>
                  <span class="rounded-full bg-[#f1eadf] px-3 py-1 text-xs font-medium">Laravel</span>
                  <span class="rounded-full bg-[#f1eadf] px-3 py-1 text-xs font-medium">APIs</span>
                </div>
              </div>

              <div class="rounded-2xl bg-[#1f2933] p-5 text-white shadow-sm">
                <p class="text-sm text-white/70">Focus</p>
                <p class="mt-2 text-xl font-semibold">
                  Fast websites, clean UX, real business results.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="px-6 py-24">
      <div class="mx-auto max-w-6xl">
        <div class="mb-12 max-w-2xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-[#9a6a3a]">
            Selected Work
          </p>

          <h2 class="font-display text-4xl font-semibold tracking-tight text-[#151922] md:text-5xl">
  Design work across digital, print, and brand experiences.
</h2>

          <p class="mt-5 text-lg leading-8 text-[#5f6875]">
            A few examples of platforms, integrations, and web systems I’ve worked on.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {projects.map((project) => (
            <article class="rounded-[2rem] border border-black/5 bg-white p-6 shadow-xl shadow-black/[0.04] transition hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/[0.08]">
              <div class="mb-6 aspect-[16/10] rounded-[1.5rem] bg-gradient-to-br from-[#efe3d2] via-[#f7f0e7] to-white"></div>

              <h3 class="text-xl font-semibold text-[#151922]">
                {project.title}
              </h3>

              <p class="mt-3 text-sm leading-6 text-[#6b7280]">
                {project.description}
              </p>

              <div class="mt-5 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="rounded-full bg-[#f1eadf] px-3 py-1 text-xs font-medium text-[#7b512a]">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="about" class="px-6 py-24">
      <div class="mx-auto max-w-6xl rounded-[2.5rem] bg-[#1f2933] p-8 text-white md:p-14">
        <div class="grid gap-10 md:grid-cols-[0.8fr_1.2fr]">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-[#f0d7b8]">
              About
            </p>

            <h2 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl">
              Engineering with a product mindset.
            </h2>
          </div>

          <div class="space-y-6 text-lg leading-8 text-white/75">
            <p>
              I help businesses create strong visual communication across digital and print. My work includes advertising graphics, landing pages, branding, presentations, packaging, and photography.

I focus on designs that are clean, polished, and practical. The goal is not just to make things look good, but to make the message clear and help the brand feel professional.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="px-6 py-24">
      <div class="mx-auto max-w-4xl text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-[#9a6a3a]">
          Contact
        </p>

        <h2 class="text-4xl font-semibold tracking-tight text-[#151922] md:text-6xl">
          Let’s build something useful.
        </h2>

        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-[#5f6875]">
          Reach out for ad graphics, landing pages, branding, presentations, packaging, photography, or full visual design support for your business.
        </p>

        <a
          href="mailto:hello@example.com"
          class="mt-10 inline-flex rounded-full bg-[#1f2933] px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-black/10 transition hover:bg-[#111827]"
        >
          hello@example.com
        </a>
      </div>
    </section>

    <footer class="border-t border-black/5 px-6 py-8">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 text-sm text-[#6b7280] md:flex-row md:items-center md:justify-between">
        <p>© 2026 Andrew Bus. All rights reserved.</p>

        <div class="flex gap-5">
          <a href="#" class="hover:text-[#1f2933]">LinkedIn</a>
          <a href="#" class="hover:text-[#1f2933]">GitHub</a>
          <a href="#" class="hover:text-[#1f2933]">Email</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>